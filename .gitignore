# Deny-all by default, then explicitly allow tracked dotfiles.
/*

# Root-level dotfiles
!/.gitconfig
!/.gitignore
!/.gitignore_global
!/Brewfile
!/README.md
!/setup.sh
!/.tigrc
!/.zshrc
!/.zprofile

# Only keep Neovim config under .config
!/.config/
/.config/*
!/.config/nvim/
!/.config/mise/
!/.config/mise/config.toml

# Claude Code skills (machine-local settings.local.json stays ignored)
!/.claude/
/.claude/*
!/.claude/skills/
!/.claude/skills/**
